<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:security="http://www.springframework.org/schema/security"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
         http://www.springframework.org/schema/beans
         http://www.springframework.org/schema/beans/spring-beans.xsd
         http://www.springframework.org/schema/security
         http://www.springframework.org/schema/security/spring-security.xsd">

  <!-- BCrypt 비밀번호 암호화 -->
  <bean id="passwordEncoder" class="org.springframework.security.crypto.bcrypt.BCryptPasswordEncoder" />

  <!-- JSP <sec:authorize access="..."> 태그용 표현식 핸들러
       (단일 컨텍스트 구조에서 authorize 태그가 빈을 직접 조회하므로 명시적으로 노출) -->
  <bean id="webSecurityExpressionHandler"
        class="org.springframework.security.web.access.expression.DefaultWebSecurityExpressionHandler" />

  <!-- URL 접근 제어 -->
  <security:http use-expressions="true">

    <!-- 정적 리소스는 보안 제외 -->
    <security:intercept-url pattern="/resources/**" access="permitAll" />

    <!-- 공개 접근 허용 -->
    <security:intercept-url pattern="/member/login" access="permitAll" />
    <security:intercept-url pattern="/member/register" access="permitAll" />
    <security:intercept-url pattern="/member/idCheck" access="permitAll" />
    <security:intercept-url pattern="/member/nicknameCheck" access="permitAll" />
    <security:intercept-url pattern="/member/emailCheck" access="permitAll" />

    <!-- M-09 얼굴 로그인: 스캔/매칭은 공개, 등록은 로그인 필요 -->
    <security:intercept-url pattern="/member/face/login" access="permitAll" />
    <security:intercept-url pattern="/member/face/loginProc" access="permitAll" />
    <security:intercept-url pattern="/member/face/register" access="isAuthenticated()" />

    <!-- 게시판 목록·상세는 누구나 열람 가능 -->
    <security:intercept-url pattern="/board/list" access="permitAll" />
    <security:intercept-url pattern="/board/detail" access="permitAll" />

    <!-- 글 작성·수정·삭제는 로그인 필요 -->
    <security:intercept-url pattern="/board/write" access="isAuthenticated()" />
    <security:intercept-url pattern="/board/edit" access="isAuthenticated()" />
    <security:intercept-url pattern="/board/delete" access="isAuthenticated()" />
    <security:intercept-url pattern="/board/like" access="isAuthenticated()" />
    <security:intercept-url pattern="/board/dislike" access="isAuthenticated()" />
    <security:intercept-url pattern="/report" access="isAuthenticated()" />
    <security:intercept-url pattern="/party/write" access="isAuthenticated()" />
    <security:intercept-url pattern="/party/status" access="isAuthenticated()" />
    <security:intercept-url pattern="/message/**" access="isAuthenticated()" />
    <security:intercept-url pattern="/notification/**" access="isAuthenticated()" />
    <security:intercept-url pattern="/comment/**" access="isAuthenticated()" />

    <!-- 마이페이지는 로그인 필요 -->
    <security:intercept-url pattern="/member/mypage/**" access="isAuthenticated()" />

    <!-- 관리자 페이지 -->
    <security:intercept-url pattern="/admin/**" access="hasRole('ADMIN')" />

    <!-- 나머지는 모두 허용 -->
    <security:intercept-url pattern="/**" access="permitAll" />

    <!-- 폼 로그인 설정 -->
    <security:form-login
        login-page="/member/login"
        login-processing-url="/member/loginProc"
        default-target-url="/"
        authentication-failure-url="/member/login?error=true"
        username-parameter="id"
        password-parameter="password" />

    <!-- M-03 소셜 로그인 (카카오/네이버/구글 OAuth2)
         인가요청: /oauth2/authorization/{kakao|naver|google}
         리다이렉트: /login/oauth2/code/{registrationId} -->
    <security:oauth2-login
        login-page="/member/login"
        authentication-failure-handler-ref="oauthFailureHandler"
        client-registration-repository-ref="clientRegistrationRepository"
        user-service-ref="customOAuth2UserService" />

    <!-- 로그아웃 설정 -->
    <security:logout
        logout-url="/member/logout"
        logout-success-url="/"
        invalidate-session="true"
        delete-cookies="JSESSIONID" />

    <!-- 학습 프로젝트용 CSRF 비활성화 -->
    <security:csrf disabled="true" />

    <!-- 403 접근 거부 처리 -->
    <security:access-denied-handler error-page="/error/403" />

  </security:http>

  <!-- 소셜 로그인 실패 시 원인을 콘솔에 찍고 우리 로그인 페이지로 (기본 /login?error 는 404) -->
  <bean id="oauthFailureHandler"
        class="kr.ac.kopo.member.security.OAuthLoggingFailureHandler" />

  <!-- 인증 매니저 -->
  <security:authentication-manager>
    <security:authentication-provider user-service-ref="memberDetailsService">
      <security:password-encoder ref="passwordEncoder" />
    </security:authentication-provider>
  </security:authentication-manager>

</beans>
